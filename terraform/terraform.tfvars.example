aws_region    = "us-east-1"
key_name      = "your-ec2-key-pair-name"
instance_type = "t3.small"

# Your public IPv4 in /32 form only Cursor + you may hit :80/:443 (not 0.0.0.0/0).
# Example: curl -4 -s ifconfig.me then append /32
allowed_proxy_cidr = "203.0.113.10/32"

# Optional: SSH from a different CIDR than the proxy (defaults to allowed_proxy_cidr).
# allowed_ssh_cidr = "198.51.100.0/24"

# Optional: junk Let's Encrypt contact (default acme-le-junk@daggrai.com). No inbox in AWS.
# certbot_junk_domain      = "daggrai.com"
# certbot_junk_local_part  = "acme-le-junk"
